{
  "manifest_version": 3,
  "name": "Accessify",
  "version": "1.0.0",
  "description": "A suite of accessibility modifications for the web.",
  "action": {
    "default_popup": "index.html",
    "default_title": "Accessibility Settings"
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "contextMenus",
    "offscreen",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "pageModifier.js",
        "features/dyslexiaFont.js",
        "features/largeCursor.js",
        "features/fontSize.js",
        "features/lineSpacing.js",
        "features/letterSpacing.js",
        "features/highContrast.js",
        "features/imageCaption.js",
        "features/bionicReading.js",
        "features/pageSummary.js",
        "features/textToSpeech.js",
        "features/smartMagnify.js",
        "content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "features/*",
        "pageModifier.js",
        "fonts/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}